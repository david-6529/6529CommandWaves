# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DATABASE_URL=""
COMMAND_WAVE_STORE="file"
# Optional first hook project seed. Used only for fresh/default state or local reset.
COMMAND_WAVE_INITIAL_NAME="6529 Hook"
COMMAND_WAVE_INITIAL_WAVE_URL=""
# Placeholder until the pilot repo is selected. PR work stays blocked while this is unchanged.
COMMAND_WAVE_INITIAL_REPO_URL="https://github.com/your-org/your-hook-repo"
# Blank keeps local demo mutation routes open. Set a strong value before production.
# Mutating command-wave API calls then require `x-admin-api-key` or `Authorization: Bearer`.
ADMIN_API_KEY=""

# 6529
6529_API_BASE_URL="https://api.6529.io"
# Defaults to mock mode unless explicitly set to "false".
6529_MOCK_MODE="true"
# Optional. Without these, builders copy drafts and post manually in project chat.
6529_BOT_BEARER_TOKEN=""
6529_BOT_WALLET_ADDRESS=""

# Agent providers
COMMAND_WAVE_ORCHESTRATOR_6529_ACCOUNT="daemon"
COMMAND_WAVE_REVIEW_AGENT_MODE="placeholder"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# Local agent/model development
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# Guardian/setup proof
# MVP mode is repo_local_github_action. Strong production mode should be external_github_app.
COMMAND_WAVE_GUARDIAN_MODE="repo_local_github_action"
COMMAND_WAVE_GUARDIAN_REQUIRED_CHECK="Command Waves Guardian"
# Repo-local guardian mode uses this workflow path. External guardian mode ignores it.
COMMAND_WAVE_GUARDIAN_WORKFLOW_PATH=".github/workflows/guardian-review.yml"
COMMAND_WAVE_GUARDIAN_PROOF_ARTIFACT="guardian-proof"
COMMAND_WAVE_GUARDIAN_REPLAY_COMMAND="npm run guardian:verify-proof"
COMMAND_WAVE_PROTECTED_BRANCH="main"
COMMAND_WAVE_VERCEL_PRODUCTION_BRANCH="main"
# Required before using the guardian as a required PR check. Use one real source.
COMMAND_WAVE_STATE_URL=""
COMMAND_WAVE_STATE_PATH=""
# Local demos only. Do not enable for production guardian checks.
COMMAND_WAVE_ALLOW_DEMO_STATE="false"

# GitHub PR adapter
# The adapter opens draft PRs only from an existing prepared branch.
COMMAND_WAVE_REPO_ADAPTER="local"
COMMAND_WAVE_GITHUB_TOKEN=""
COMMAND_WAVE_GITHUB_BASE_BRANCH="main"
