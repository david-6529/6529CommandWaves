# First public hook room
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.example
ADMIN_API_KEY=replace-with-a-strong-random-key

# Durable audit storage
COMMAND_WAVE_STORE=postgres
DATABASE_URL=postgresql://user:password@host:5432/command_waves

# Live 6529 reads
6529_API_BASE_URL=https://api.6529.io
6529_MOCK_MODE=false

# Guardian state source for required PR checks
COMMAND_WAVE_STATE_URL=https://your-app.example/api/command-wave/state
COMMAND_WAVE_STATE_PATH=
COMMAND_WAVE_ALLOW_DEMO_STATE=false

# Guardian setup proof
COMMAND_WAVE_GUARDIAN_MODE=repo_local_github_action
COMMAND_WAVE_GUARDIAN_REQUIRED_CHECK=Command Waves Guardian
COMMAND_WAVE_GUARDIAN_WORKFLOW_PATH=.github/workflows/guardian-review.yml
COMMAND_WAVE_GUARDIAN_PROOF_ARTIFACT=guardian-proof
COMMAND_WAVE_GUARDIAN_REPLAY_COMMAND=npm run guardian:verify-proof
COMMAND_WAVE_PROTECTED_BRANCH=main
COMMAND_WAVE_VERCEL_PRODUCTION_BRANCH=main

# GitHub PR adapter, optional for first loop but recommended before broad use
COMMAND_WAVE_REPO_ADAPTER=github
COMMAND_WAVE_GITHUB_TOKEN=replace-with-github-token
COMMAND_WAVE_GITHUB_BASE_BRANCH=main

# 6529 room posting, optional. Without these, humans copy drafts and post manually.
6529_BOT_BEARER_TOKEN=
6529_BOT_WALLET_ADDRESS=
